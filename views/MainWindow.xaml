<Window x:Class="SteamReqDesktopWPF.views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Steam Hardware Scanner" Height="900" Width="1600" Background="#1b2838" TextElement.Foreground="WhiteSmoke">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <StackPanel Margin="20">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                    <Image Source="/images/pc_white.png" Width="32" Height="32" Margin="0,0,8,0" SnapsToDevicePixels="True" UseLayoutRounding="True" RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="Your System" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                    <Image Source="/images/cpu_white.png" Width="32" Height="32" Margin="0,0,8,0" SnapsToDevicePixels="True" UseLayoutRounding="True" RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock>
                    <Run Text="CPU: " FontWeight="Bold" FontSize="16" />
                    <Run Text="{Binding UserHardware.CPU_print_name}" FontSize="16" />
                    </TextBlock>

                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                    <Image Source="/images/gpu_white.png" Width="32" Height="32" Margin="0,0,8,0" SnapsToDevicePixels="True" UseLayoutRounding="True" RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock>
                    <Run Text="GPU: " FontWeight="Bold" FontSize="16" />
                    <Run Text="{Binding UserHardware.GPU_print_name}" FontSize="16" />                  
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                    <Image Source="/images/ram_white.png" Width="32" Height="32" Margin="0,0,8,0" SnapsToDevicePixels="True" UseLayoutRounding="True" RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock>
                    <Run Text="Ram:" FontWeight="Bold" FontSize="16" />
                    <Run Text="{Binding UserHardware.Mem_Size, StringFormat=' {0} GB'}" FontSize="16" />      
                    </TextBlock>
                    <TextBlock Text="{Binding UserHardware.Mem_Size, StringFormat='RAM: {0} GB'}" FontSize="16"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                    <Image Source="/images/hd_white.png" Width="32" Height="32" Margin="0,0,8,0" SnapsToDevicePixels="True" UseLayoutRounding="True" RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="Storage Drives:" FontWeight="Bold" Margin="0,15,0,5" />
                </StackPanel>
                <ItemsControl ItemsSource="{Binding UserHardware.Drive_List}" 
                         BorderThickness="0" 
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                <TextBlock Text="{Binding DriveLetter, StringFormat='Drive {0}'}" FontWeight="Bold" Width="60" Foreground="WhiteSmoke"/>
                                <TextBlock Text="{Binding FreeSpace, StringFormat='{}{0:N2} GB Free'}" Foreground="WhiteSmoke" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Grid.Column="1">

                <TextBlock Text="Enter Steam Game URL or Search for a Game:" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" >
                    <ui:TextBox Text="{Binding SteamUrlInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10" Padding="2" Width="685" Height="32" RenderTransformOrigin="0.501,0.487" HorizontalAlignment="Center">
                        <ui:TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding RunScanCommand}" />
                        </ui:TextBox.InputBindings>
                    </ui:TextBox>
                    <ui:Button Content="Search Games" Command="{Binding RunScanCommand}" Padding="5" Margin="10,0,0,6" Height="31" FontSize="16" Width="149" Icon="{ui:SymbolIcon Symbol='Search12'}"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding SearchResults}" 
                         Visibility="{Binding IsShowingSearchResults, Converter={StaticResource BoolToVis}}" 
                         MaxHeight="400" 
                         Margin="0,3,0,3" 
                         ScrollViewer.VerticalScrollBarVisibility="Auto">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Background" Value="#16212e" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#afcbdf" />
                                    <Setter Property="Foreground" Value="#3e4b54" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#afcbdf" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Background="Transparent">
                                <Grid.InputBindings>
                                    <MouseBinding Gesture="LeftClick" 
                                  Command="{Binding DataContext.SelectGameCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                  CommandParameter="{Binding AppID}"/>
                                </Grid.InputBindings>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <Image Source="{Binding ImageURL}" Width="120" Height="45" Margin="0,0,10,0" />
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" VerticalAlignment="Center" FontSize="16" Foreground="WhiteSmoke" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,20" FontStyle="Italic" Foreground="WhiteSmoke" />

                <Grid Visibility="{Binding IsScanComplete, Converter={StaticResource BoolToVis}}" 
                      HorizontalAlignment="Left" 
                      MaxWidth="900" 
                      Margin="0,0,0,20" Width="685">

                    <Border CornerRadius="10" Background="#15FFFFFF">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="15" ShadowDepth="5" Direction="270" />
                        </Border.Effect>
                    </Border>

                    <Border CornerRadius="10" BorderBrush="#30FFFFFF" BorderThickness="1" Padding="30" HorizontalAlignment="Left" Width="685">

                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="550" Padding="0,0,15,0">

                            <StackPanel>
                                <Image Source="{Binding GameRequirements.Game_image_url, FallbackValue={x:Null}, TargetNullValue={x:Null}}" 
                                       Width="562" Height="174" Margin="0,0,0,5" HorizontalAlignment="Center" 
                                       SnapsToDevicePixels="True" UseLayoutRounding="True" RenderOptions.BitmapScalingMode="HighQuality" />

                                <TextBlock Text="{Binding GameRequirements.Game_Name}" TextAlignment="Center" Padding="2" FontWeight="Bold" FontSize="32" Margin="0,0,0,30" Foreground="WhiteSmoke"/>

                                <Grid Margin="0,0,0,40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                        <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,10" Text="Minimum Requirements" Foreground="WhiteSmoke"/>

                                        <TextBlock FontWeight="Bold" Margin="0,5,0,0" Text="CPUs:" Foreground="WhiteSmoke"/>
                                        <ItemsControl ItemsSource="{Binding GameRequirements.min_cpu_names}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="WhiteSmoke"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock FontWeight="Bold" Margin="0,5,0,0" Text="GPUs:" Foreground="WhiteSmoke"/>
                                        <ItemsControl ItemsSource="{Binding GameRequirements.min_gpu_names}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="WhiteSmoke"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Margin="0,5,0,0" Foreground="WhiteSmoke">
                                            <Run Text="RAM: " FontWeight="Bold" />
                                            <Run Text="{Binding GameRequirements.Min_ram, StringFormat='{}{0} GB'}" />
                                        </TextBlock>

                                        <TextBlock Text="{Binding GameRequirements.DisplayStorage}" Foreground="WhiteSmoke"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                        <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,10" Text="Recommended Requirements" Foreground="WhiteSmoke"/>

                                        <TextBlock FontWeight="Bold" Margin="0,5,0,0" Text="CPUs:" Foreground="WhiteSmoke"/>
                                        <ItemsControl ItemsSource="{Binding GameRequirements.rec_cpu_names}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="WhiteSmoke"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock FontWeight="Bold" Margin="0,5,0,0" Text="GPUs:" Foreground="WhiteSmoke"/>
                                        <ItemsControl ItemsSource="{Binding GameRequirements.rec_gpu_names}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="WhiteSmoke"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Margin="0,5,0,0" Foreground="WhiteSmoke">
                                            <Run Text="RAM: " FontWeight="Bold" />
                                            <Run Text="{Binding GameRequirements.Rec_ram, StringFormat='{}{0} GB'}" />
                                        </TextBlock>

                                        <TextBlock Text="{Binding GameRequirements.DisplayStorage}" Foreground="WhiteSmoke"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Text="Results" TextAlignment="Center" Foreground="WhiteSmoke"/>

                                    <TextBlock FontWeight="SemiBold" Margin="0,5,0,0" Text="{Binding Cpu_result}" TextAlignment="Center" TextWrapping="Wrap" Foreground="WhiteSmoke"/>
                                    <TextBlock FontWeight="SemiBold" Margin="0,5,0,0" Text="{Binding Gpu_result}" TextAlignment="Center" TextWrapping="Wrap" Foreground="WhiteSmoke"/>
                                    <TextBlock FontWeight="SemiBold" Margin="0,5,0,0" Text="{Binding Ram_result}" TextAlignment="Center" TextWrapping="Wrap" Foreground="WhiteSmoke"/>

                                    <TextBlock FontWeight="SemiBold" Margin="0,15,0,5" Text="Hard drives with enough space:" TextAlignment="Center" TextWrapping="Wrap" Foreground="WhiteSmoke"/>
                                    <ItemsControl HorizontalAlignment="Center" ItemsSource="{Binding Drives_with_space}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock HorizontalAlignment="Center" Margin="0,2,0,0" Text="{Binding}" Foreground="WhiteSmoke"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

            </StackPanel>
        </Grid>
    </StackPanel>
</Window>